{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/Rul1an/assay/v3.8.0/docs/reference/receipt-schemas/inputs/pydantic-case-result-export.v1.schema.json",
  "title": "Assay-supported Pydantic Evals Reduced Case-Result Export Row v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "framework", "surface", "case_name", "results", "timestamp"],
  "properties": {
    "schema": { "const": "pydantic-evals.report-case-result.export.v1" },
    "framework": { "const": "pydantic_evals" },
    "surface": { "const": "evaluation_report.cases.case_result" },
    "case_name": { "$ref": "#/$defs/boundedString" },
    "source_case_name": { "$ref": "#/$defs/boundedString" },
    "source_ref": { "$ref": "#/$defs/boundedString" },
    "results": {
      "type": "array",
      "minItems": 1,
      "maxItems": 32,
      "items": { "$ref": "#/$defs/result" }
    },
    "timestamp": { "type": "string", "format": "date-time" }
  },
  "$defs": {
    "boundedString": {
      "type": "string",
      "minLength": 1,
      "maxLength": 160,
      "pattern": "^[^\\r\\n\\\"`{}]+$"
    },
    "reasonString": {
      "type": "string",
      "minLength": 1,
      "maxLength": 240,
      "pattern": "^[^\\r\\n\\\"`{}]+$"
    },
    "result": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "evaluator_name"],
      "properties": {
        "kind": { "enum": ["assertion", "score"] },
        "evaluator_name": { "$ref": "#/$defs/boundedString" },
        "passed": { "type": "boolean" },
        "score": { "type": "number" },
        "reason": { "$ref": "#/$defs/reasonString" }
      },
      "oneOf": [
        {
          "required": ["passed"],
          "properties": {
            "kind": { "const": "assertion" }
          },
          "not": { "required": ["score"] }
        },
        {
          "required": ["score"],
          "properties": {
            "kind": { "const": "score" }
          },
          "not": { "required": ["passed"] }
        }
      ]
    }
  }
}
