{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/Rul1an/assay/main/docs/experiments/mcp-tool-evidence-binding-harness-2026-05/schema/mcp-tool-binding-cell-v0.schema.json",
  "title": "Assay MCP tool evidence binding cell v0",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "scenario_id",
    "role",
    "claim_outcome",
    "created_at",
    "assay_commit",
    "context_descriptor_set_ref",
    "context_descriptor_set_digest",
    "model_visible_tool_description_refs",
    "co_visible_tool_names",
    "called_tool_name",
    "called_tool_manifest_digest",
    "called_tool_description_digest",
    "tool_call_ref",
    "tool_call_id",
    "call_observed",
    "measured_effect_ref",
    "measured_effect_kind",
    "effect_capture_status",
    "effect_within_declared_boundary",
    "description_matches_manifest",
    "required_links_complete",
    "join_key",
    "join_grade",
    "transport_profile",
    "transport_context",
    "mapping_notes",
    "non_claims"
  ],
  "properties": {
    "schema": {
      "const": "assay.experiment.mcp_tool_evidence_binding.binding_cell.v0"
    },
    "scenario_id": {
      "type": "string",
      "enum": [
        "benign_tool_call_bound",
        "description_changed_before_call",
        "effect_outside_declared_tool_boundary",
        "description_visible_no_call",
        "call_made_no_measurable_effect",
        "call_made_with_other_descriptions_visible"
      ]
    },
    "role": {
      "type": "string",
      "enum": [
        "baseline",
        "drift",
        "gap",
        "absence_boundary",
        "effect_boundary",
        "context_boundary"
      ]
    },
    "claim_outcome": {
      "type": "string",
      "enum": [
        "bound_tool_evidence",
        "description_drift",
        "effect_outside_declared_tool_boundary",
        "call_isolated_in_visible_context",
        "diagnostic_only",
        "inconclusive"
      ]
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "assay_commit": {
      "type": "string",
      "minLength": 1
    },
    "context_descriptor_set_ref": {
      "type": "string",
      "minLength": 1
    },
    "context_descriptor_set_digest": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "model_visible_tool_description_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/visible_tool_description_ref"
      }
    },
    "co_visible_tool_names": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "called_tool_name": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "called_tool_manifest_digest": {
      "type": [
        "string",
        "null"
      ],
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "called_tool_description_digest": {
      "type": [
        "string",
        "null"
      ],
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "tool_call_ref": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "tool_call_id": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "call_observed": {
      "type": "boolean"
    },
    "measured_effect_ref": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "measured_effect_kind": {
      "type": "string",
      "enum": [
        "filesystem_read",
        "filesystem_write",
        "none"
      ]
    },
    "effect_capture_status": {
      "type": "string",
      "enum": [
        "observed",
        "unobserved",
        "not_applicable",
        "unavailable"
      ]
    },
    "effect_within_declared_boundary": {
      "type": [
        "boolean",
        "null"
      ]
    },
    "description_matches_manifest": {
      "type": [
        "boolean",
        "null"
      ]
    },
    "required_links_complete": {
      "type": "boolean"
    },
    "join_key": {
      "type": "string",
      "enum": [
        "tool_call_id",
        "tool_name",
        "none"
      ]
    },
    "join_grade": {
      "type": "string",
      "enum": [
        "strong",
        "diagnostic",
        "failed"
      ]
    },
    "transport_profile": {
      "type": "string",
      "enum": [
        "local_synthetic",
        "mcp_tunnel_synthetic"
      ]
    },
    "transport_context": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": false,
      "required": [
        "kind",
        "transport_profile",
        "connection_direction",
        "proxy_role",
        "payload_tls_boundary",
        "upstream_authentication",
        "metadata_visible_to_transport_provider",
        "transport_claim"
      ],
      "properties": {
        "kind": {
          "const": "synthetic_mcp_tunnel_transport_context"
        },
        "transport_profile": {
          "const": "mcp_tunnel_synthetic"
        },
        "connection_direction": {
          "const": "outbound_only"
        },
        "proxy_role": {
          "type": "string",
          "minLength": 1
        },
        "payload_tls_boundary": {
          "type": "string",
          "minLength": 1
        },
        "upstream_authentication": {
          "type": "string",
          "minLength": 1
        },
        "metadata_visible_to_transport_provider": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "transport_claim": {
          "const": "transport_context_only"
        }
      }
    },
    "mapping_notes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "non_claims": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1,
        "pattern": "^[a-z][a-z0-9_]*$"
      }
    }
  },
  "$defs": {
    "visible_tool_description_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tool_name",
        "ref",
        "source_surface",
        "digest",
        "declared_boundary"
      ],
      "properties": {
        "tool_name": {
          "type": "string",
          "minLength": 1
        },
        "ref": {
          "type": "string",
          "minLength": 1
        },
        "source_surface": {
          "type": "string",
          "enum": [
            "synthetic_mcp_tools_list"
          ]
        },
        "digest": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        },
        "declared_boundary": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "claim_outcome": {
            "const": "bound_tool_evidence"
          }
        }
      },
      "then": {
        "properties": {
          "call_observed": {
            "const": true
          },
          "required_links_complete": {
            "const": true
          },
          "join_key": {
            "const": "tool_call_id"
          },
          "join_grade": {
            "const": "strong"
          },
          "effect_capture_status": {
            "const": "observed"
          },
          "effect_within_declared_boundary": {
            "const": true
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "claim_outcome": {
            "const": "description_drift"
          }
        }
      },
      "then": {
        "properties": {
          "description_matches_manifest": {
            "const": false
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "claim_outcome": {
            "const": "effect_outside_declared_tool_boundary"
          }
        }
      },
      "then": {
        "properties": {
          "call_observed": {
            "const": true
          },
          "effect_capture_status": {
            "const": "observed"
          },
          "effect_within_declared_boundary": {
            "const": false
          },
          "join_key": {
            "const": "tool_call_id"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "claim_outcome": {
            "const": "call_isolated_in_visible_context"
          }
        }
      },
      "then": {
        "properties": {
          "call_observed": {
            "const": true
          },
          "required_links_complete": {
            "const": true
          },
          "co_visible_tool_names": {
            "type": "array",
            "minItems": 2
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "claim_outcome": {
            "const": "inconclusive"
          }
        }
      },
      "then": {
        "properties": {
          "required_links_complete": {
            "const": false
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "transport_profile": {
            "const": "mcp_tunnel_synthetic"
          }
        }
      },
      "then": {
        "properties": {
          "transport_context": {
            "type": "object"
          }
        }
      }
    }
  ]
}
