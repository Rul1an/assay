{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/Rul1an/assay/v3.8.0/docs/reference/receipt-schemas/inputs/livekit-function-tools-executed-export.v1.schema.json",
  "title": "Assay-supported LiveKit FunctionToolsExecutedEvent Export v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "framework",
    "surface",
    "runtime_mode",
    "event_ref",
    "created_at",
    "function_calls",
    "function_call_outputs"
  ],
  "properties": {
    "schema": { "const": "livekit.function-tools-executed.export.v1" },
    "framework": { "const": "livekit_agents" },
    "surface": { "const": "function_tools_executed" },
    "runtime_mode": { "const": "agent_session" },
    "type": { "const": "function_tools_executed" },
    "event_ref": { "$ref": "#/$defs/boundedRef" },
    "created_at": { "$ref": "#/$defs/timestamp" },
    "function_calls": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/functionCall" }
    },
    "function_call_outputs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "oneOf": [
          { "$ref": "#/$defs/functionCallOutput" },
          { "type": "null" }
        ]
      }
    },
    "has_tool_reply": { "type": "boolean" },
    "has_agent_handoff": { "type": "boolean" }
  },
  "$defs": {
    "timestamp": {
      "oneOf": [
        { "type": "string", "format": "date-time" },
        { "type": "number" }
      ]
    },
    "boundedRef": {
      "type": "string",
      "minLength": 1,
      "maxLength": 240,
      "pattern": "^[^\\r\\n\\\"`{}]+$"
    },
    "boundedName": {
      "type": "string",
      "minLength": 1,
      "maxLength": 160,
      "pattern": "^[^\\r\\n\\\"`{}]+$"
    },
    "functionCall": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name"],
      "properties": {
        "id": { "$ref": "#/$defs/boundedRef" },
        "type": { "$ref": "#/$defs/boundedRef" },
        "call_id": { "$ref": "#/$defs/boundedRef" },
        "name": { "$ref": "#/$defs/boundedName" },
        "arguments": true,
        "arguments_ref": { "$ref": "#/$defs/boundedRef" },
        "created_at": { "$ref": "#/$defs/timestamp" },
        "group_id": {
          "oneOf": [
            { "$ref": "#/$defs/boundedRef" },
            { "type": "null" }
          ]
        }
      },
      "not": { "required": ["arguments", "arguments_ref"] }
    },
    "functionCallOutput": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "is_error"],
      "properties": {
        "id": { "$ref": "#/$defs/boundedRef" },
        "type": { "$ref": "#/$defs/boundedRef" },
        "call_id": { "$ref": "#/$defs/boundedRef" },
        "name": { "$ref": "#/$defs/boundedName" },
        "output": true,
        "output_ref": { "$ref": "#/$defs/boundedRef" },
        "is_error": { "type": "boolean" },
        "created_at": { "$ref": "#/$defs/timestamp" }
      },
      "not": { "required": ["output", "output_ref"] }
    }
  }
}
